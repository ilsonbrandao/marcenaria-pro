# ===== PostgreSQL (Coolify) =====
# Em produção (app no Coolify) use o host INTERNO do recurso Postgres.
# Em desenvolvimento local, use o host público temporário do Coolify.
DATABASE_URL=postgres://USUARIO:SENHA@HOST:5432/marcenaria
# Defina como "false" para desativar SSL (Postgres do Coolify sem SSL)
DATABASE_SSL=false

# ===== Auth.js (NextAuth v5) =====
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ===== DigitalOcean Spaces (storage S3) =====
SPACES_ENDPOINT=https://REGIAO.digitaloceanspaces.com
SPACES_REGION=REGIAO
SPACES_BUCKET=NOME_DO_BUCKET
SPACES_KEY=
SPACES_SECRET=
# Opcional: base pública/CDN (senão derivada de bucket+endpoint)
# SPACES_PUBLIC_BASE=https://NOME_DO_BUCKET.REGIAO.cdn.digitaloceanspaces.com

# ===== URL pública da aplicação (links de orçamento) =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
